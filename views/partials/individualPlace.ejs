<div class="card-body bg-light">
    <h5 class="card-title">投稿者：<%= allUser.length %>人</h5>
    <h5 class="card-title">投票者：<%= user.votedpoints.length %>人</h5>
</div>
</div>
<div class="card m-auto mt-4 shadow bg-body rounded" style="width: 80%;">
<div class="mt-3 row">
    <div class="col-12 text-center">
        <p>
            ボケ
        </p>
    </div>
    <div class="col-12 text-center">
        <p>
            <%= user.joke %>
            <br>（<%= user.username %>）
        </p>
    </div>
</div>
</div>
<div class="card m-auto mt-4 mb-5 bg-light shadow bg-body rounded" style="width: 80%;">
<div class="row mt-3">
    <div class="col-2 text-center">
        <p>点</p>
    </div>
    <div class="col-10 text-center">
        <p>投票者</p>
    </div>
    <% const voters = user.votedpoints.filter((num) => num.votepoint !==0);
    for(let voter of voters) {  %>
        <div class="col-2 text-center">
        <p><%= voter.votepoint %>点</p>
    </div>
    <div class="col-10 text-center">
        <p><%= voter.voteuser %></p>
    </div>
    <% } %> 
</div>
</div>