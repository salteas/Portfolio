<% layout("layouts/boilerplate") %>

    <h2>得点の詳細</h2>
    <div class="card m-auto mt-4 shadow bg-body rounded" style="width: 100%;">
        <div class="mt-5 mb-5 m-auto">
            <p class="card-title ps-3 pe-3 ps-lg-2 pe-lg-2 p-font">お題A</p>
            <p class="m-auto mt-3 ps-2 pe-2 ps-lg-1 pe-lg-1 p-font-title text-center"><b><%= user.theme %></b></p>
        </div>
        <div class="card-body bg-light">
            <h5 class="card-title">投稿者：<%= allUser.length %>人</h5>
            <h5 class="card-title">投票者：<%= user.votedpoints.length %>人</h5>
        </div>
    </div>
    <div class="card m-auto mt-4 shadow bg-body rounded" style="width: 90%;">
        <div class="mt-3 row m-auto" style="width: 95%;">
            <div class="col-12 text-center">
                <p>
                    ボケ
                </p>
            </div>
            <div class="col-12 text-center">
                <p>
                    <%= user.joke %>
                    <br>（<%= user.username %>）
                </p>
            </div>
        </div>
    </div>
    <div class="card m-auto mt-4 mb-5 bg-light shadow bg-body rounded" style="width: 90%;">
        <div class="row mt-3 m-auto" style="width: 95%;">
            <div class="col-2 text-center">
                <p>点</p>
            </div>
            <div class="col-10 text-center">
                <p>投票者</p>
            </div>
            <% const voters = user.votedpoints.filter((num) => num.votepoint !==0);
            for(let voter of voters) {  %>
                <div class="col-2 text-center">
                <p><%= voter.votepoint %>点</p>
            </div>
            <div class="col-10 text-center">
                <p><%= voter.voteuser %></p>
            </div>
            <% } %> 
        </div>
    </div>